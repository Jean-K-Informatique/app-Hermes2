# ─── Server ───────────────────────────────────
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# ─── Database ─────────────────────────────────
# SQLite (development):
DATABASE_URL=file:./dev.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://hermeschat:password@localhost:5432/hermeschat

# ─── Authentication ───────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-string-for-production-use-only
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# ─── Encryption ───────────────────────────────
# 32 bytes hex for AES-256-GCM. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string-for-production

# ─── Whisper (Transcription) ──────────────────
# Options: api | local | disabled
WHISPER_MODE=disabled
WHISPER_API_KEY=sk-your-openai-api-key
WHISPER_MODEL=whisper-1
WHISPER_LOCAL_MODEL=base

# ─── Push Notifications ──────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token

# ─── Rate Limiting ───────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ─── Mock Mode ───────────────────────────────
# Set to true to use mock Hermes responses (no real AI backend needed)
MOCK_HERMES=true
